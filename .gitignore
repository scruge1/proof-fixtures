# Source documents downloaded by build_corpus.py — too heavy for git
fixtures/*/samples/*.pdf
fixtures/*/samples/*.jpg
fixtures/*/samples/*.jpeg
fixtures/*/samples/*.png
fixtures/*/samples/*.tif
fixtures/*/samples/*.tiff

# Python runtime
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Benchmark intermediate
results/*.json
results/*.csv
!results/.gitkeep

# v0.4.2 Step 6 large balanced corpus runs — reproducible from seed (master+per-family),
# too heavy for git. Smoke (corpus/synth-prototype/) and corrupted-smoke stay tracked
# as canonical references; full balanced runs (32+/family) regenerate on demand via
# scripts/generate_corpus_full.py.
corpus/synth-full-*/
corpus/synth-sanity-check/
corpus/_full-run-r1.log
corpus/_*.log

# Pilot subsets generated by scripts/run_baseline.py --doc-limit
fixtures/*__pilot*/
